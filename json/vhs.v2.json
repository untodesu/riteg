{
  "textures": {
    "noise": {
      "width": 320,
      "height": 480,
      "filter": false
    },
    "image_noise": {
      "width": 320,
      "height": 480,
      "filter": true
    },
    "yiq": {
      "width": 640,
      "height": 480,
      "filter": true
    },
    "yiq_luma_haze": {
      "width": 640,
      "height": 480,
      "filter": true
    },
    "yiq_luma_blur": {
      "width": 640,
      "height": 480,
      "filter": true
    },
    "yiq_chroma_blur": {
      "width": 320,
      "height": 480,
      "filter": true
    },
    "yiq_combined": {
      "width": 640,
      "height": 480,
      "filter": true
    },
    "rgb": {
      "width": 640,
      "height": 480,
      "filter": true
    },
    "final": {
      "width": 640,
      "height": 480,
      "filter": true
    }
  },
  "blit": "final",
  "passes": [
    {
      "shader": "shaders/vhs_gen_noise.frag",
      "samplers": [],
      "output": "noise",
      "params": [ 0.9996 ]
    },
    {
      "shader": "shaders/blend_add.frag",
      "samplers": [ "image", "noise" ],
      "output": "image_noise",
      "params": [ 1.0, 1.0 ]
    },
    {
      "shader": "shaders/convert_rgb_to_yiq.frag",
      "samplers": [ "image_noise" ],
      "output": "yiq",
      "params": []
    },
    {
      "shader": "shaders/vhs_distort_yiq.frag",
      "samplers": [ "yiq" ],
      "output": "yiq_luma_haze",
      "params": [ 8, 1.5 ]
    },
    {
      "shader": "shaders/blur_fast5.frag",
      "samplers": [ "yiq_luma_haze" ],
      "output": "yiq_luma_blur",
      "params": [ 0.25, 0.0 ]
    },
    {
      "shader": "shaders/blur_fast13.frag",
      "samplers": [ "yiq" ],
      "output": "yiq_chroma_blur",
      "params": [ 1.0, 0.0 ]
    },
    {
      "shader": "shaders/vhs_combine_yiq.frag",
      "samplers": [ "yiq_luma_blur", "yiq_chroma_blur" ],
      "output": "yiq_combined",
      "params": []
    },
    {
      "shader": "shaders/convert_yiq_to_rgb.frag",
      "samplers": [ "yiq_combined" ],
      "output": "rgb",
      "params": []
    },
    {
      "shader": "shaders/vhs_distort_uv.frag",
      "samplers": [ "rgb" ],
      "output": "final",
      "params": [ 2, 1, 32 ]
    }
  ]
}
