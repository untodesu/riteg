{
  "textures": {
    "dropout":            { "width": 320, "height": 240, "filter": true },
    "gamma":              { "width": 640, "height": 240, "filter": true },
    "cutoff":             { "width": 640, "height": 240, "filter": true },
    "yiq":                { "width": 640, "height": 240, "filter": true },
    "luminance_lpx":      { "width": 640, "height": 240, "filter": true },
    "luminance_lpy":      { "width": 640, "height": 240, "filter": true },
    "luminance":          { "width": 640, "height": 240, "filter": true },
    "chrominance_noise":  { "width": 320, "height": 240, "filter": true },
    "chrominance":        { "width": 320, "height": 240, "filter": true },
    "composite":          { "width": 640, "height": 240, "filter": true },
    "snow":               { "width": 640, "height": 240, "filter": true },
    "headswitch":         { "width": 640, "height": 240, "filter": true },
    "tracking":           { "width": 640, "height": 240, "filter": true },
    "dropout_combine":    { "width": 640, "height": 240, "filter": true },
    "result":             { "width": 640, "height": 240, "filter": true }
  },
  "blit": "result",
  "passes": [
    {
      "shader": "shaders/vhs_dropout.frag",
      "samplers": [],
      "output": "dropout",
      "params": [0.0001, 0.001, 20, 0.0, 0.01, 4.0, 16.0]
    },
    {
      "shader": "shaders/video_gamma.frag",
      "samplers": ["!image"],
      "output": "gamma",
      "params": [0.7]
    },
    {
      "shader": "shaders/vhs_cutoff.frag",
      "samplers": ["gamma"],
      "output": "cutoff",
      "params": [0.005, 0.010]
    },
    {
      "shader": "shaders/color_rgb_to_yiq.frag",
      "samplers": ["cutoff"],
      "output": "yiq",
      "params": []
    },
    {
      "shader": "shaders/blur_linear_exp.frag",
      "samplers": ["yiq"],
      "output": "luminance_lpx",
      "params": [64, 3.0, 8.0, 0.0]
    },
    {
      "shader": "shaders/blur_linear_exp.frag",
      "samplers": ["yiq"],
      "output": "luminance_lpy",
      "params": [64, 3.0, 16.0, 0.0]
    },
    {
      "shader": "shaders/subtract.frag",
      "samplers": ["luminance_lpx", "luminance_lpy"],
      "output": "luminance",
      "params": [2.0, 1.0]
    },
    {
      "shader": "shaders/vhs_chrominance_noise.frag",
      "samplers": ["yiq"],
      "output": "chrominance_noise",
      "params": [0.125, 0.05, 50, 0.02]
    },
    {
      "shader": "shaders/blur_linear_exp.frag",
      "samplers": ["chrominance_noise"],
      "output": "chrominance",
      "params": [64, 3.0, 16.0, 0.0, 0.5, 0.5]
    },
    {
      "shader": "shaders/vhs_swizzle_yiq.frag",
      "samplers": ["luminance", "chrominance"],
      "output": "composite",
      "params": []
    },
    {
      "shader": "shaders/vhs_snow.frag",
      "samplers": ["composite"],
      "output": "snow",
      "params": [30, 0.01, 0.01]
    },
    {
      "shader": "shaders/vhs_headswitch.frag",
      "samplers": ["snow"],
      "output": "headswitch",
      "params": [1, 2, 0.05, 0.5]
    },
    {
      "shader": "shaders/vhs_tracking.frag",
      "samplers": ["headswitch"],
      "output": "tracking",
      "params": [60, 4.0, 4]
    },
    {
      "shader": "shaders/vhs_dropout_combine.frag",
      "samplers": ["tracking", "dropout"],
      "output": "dropout_combine",
      "params": []
    },
    {
      "shader": "shaders/color_yiq_to_rgb.frag",
      "samplers": ["dropout_combine"],
      "output": "result",
      "params": []
    }
  ]
}
