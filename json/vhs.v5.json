{
  "textures": {
    "gamma":        { "width": 640, "height": 480, "filter": true },
    "cutoff":       { "width": 640, "height": 480, "filter": true },
    "yiq":          { "width": 640, "height": 480, "filter": true },
    "ntsc":         { "width": 640, "height": 240, "filter": true },
    "dropout":      { "width": 640, "height": 240, "filter": true },
    "snow":         { "width": 640, "height": 240, "filter": true },
    "ntsc_yiq":     { "width": 640, "height": 240, "filter": true },
    "composite":    { "width": 640, "height": 240, "filter": true },
    "headswitch":   { "width": 640, "height": 240, "filter": true },
    "tracking":     { "width": 640, "height": 240, "filter": true },
    "result":       { "width": 640, "height": 240, "filter": true }
  },
  "blit": "result",
  "passes": [
    {
      "shader": "shaders/video_gamma.frag",
      "samplers": ["!image"],
      "output": "gamma",
      "params": [0.6]
    },
    {
      "shader": "shaders/video_cutoff.frag",
      "samplers": ["gamma"],
      "output": "cutoff",
      "params": [0.005, 0.010]
    },
    {
      "shader": "shaders/color_rgb_to_yiq.frag",
      "samplers": ["cutoff"],
      "output": "yiq",
      "params": []
    },
    {
      "shader": "shaders/ntsc_modulate.frag",
      "samplers": ["yiq"],
      "output": "ntsc",
      "params": []
    },
    {
      "shader": "shaders/video_dropout.frag",
      "samplers": ["ntsc"],
      "output": "dropout",
      "params": [0.0001, 0.001, 20, 0.0, 0.01, 8.0, 32.0]
    },
    {
      "shader": "shaders/video_snow.frag",
      "samplers": ["dropout"],
      "output": "snow",
      "params": [1.0, 0.0625]
    },
    {
      "shader": "shaders/ntsc_demodulate.frag",
      "samplers": ["snow"],
      "output": "ntsc_yiq",
      "params": []
    },
    {
      "shader": "shaders/ntsc_postprocess.frag",
      "samplers": ["ntsc_yiq"],
      "output": "composite",
      "params": [1.0, 60.0]
    },
    {
      "shader": "shaders/video_headswitch.frag",
      "samplers": ["composite"],
      "output": "headswitch",
      "params": [2, 2, 0.05, 0.5]
    },
    {
      "shader": "shaders/video_tracking.frag",
      "samplers": ["headswitch"],
      "output": "tracking",
      "params": [60, 4.0, 2]
    },
    {
      "shader": "shaders/color_yiq_to_rgb.frag",
      "samplers": ["tracking"],
      "output": "result",
      "params": []
    }
  ]
}
