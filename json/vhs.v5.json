{
  "textures": {
    "gamma":              { "width": 640, "height": 240, "filter": true },
    "cutoff":             { "width": 640, "height": 240, "filter": true },
    "yiq":                { "width": 640, "height": 240, "filter": true },
    "luminance_lp_a":     { "width": 640, "height": 240, "filter": true },
    "luminance_lp_b":     { "width": 640, "height": 240, "filter": true },
    "luminance":          { "width": 640, "height": 240, "filter": true },
    "chrominance_noise":  { "width": 640, "height": 240, "filter": true },
    "chrominance_lp":     { "width": 640, "height": 240, "filter": true },
    "chrominance":        { "width": 640, "height": 240, "filter": true },
    "yiq_swizzle":        { "width": 640, "height": 240, "filter": true },
    "dropout":            { "width": 640, "height": 240, "filter": true },
    "headswitch":         { "width": 640, "height": 240, "filter": true },
    "tracking":           { "width": 640, "height": 240, "filter": true },
    "result":             { "width": 640, "height": 240, "filter": true }
  },
  "blit": "result",
  "passes": [
    {
      "shader": "shaders/video_gamma.frag",
      "samplers": ["!image"],
      "output": "gamma",
      "params": [0.8]
    },
    {
      "shader": "shaders/vhs_cutoff.frag",
      "samplers": ["gamma"],
      "output": "cutoff",
      "params": [0.005, 0.010]
    },
    {
      "shader": "shaders/color_rgb_to_yiq.frag",
      "samplers": ["cutoff"],
      "output": "yiq",
      "params": []
    },
    {
      "shader": "shaders/fir_lowpass.frag",
      "samplers": ["yiq"],
      "output": "luminance_lp_a",
      "params": [16, 0.50, 1.0]
    },
    {
      "shader": "shaders/fir_lowpass.frag",
      "samplers": ["yiq"],
      "output": "luminance_lp_b",
      "params": [64, 0.25, 1.0]
    },
    {
      "shader": "shaders/subtract.frag",
      "samplers": ["luminance_lp_a", "luminance_lp_b"],
      "output": "luminance",
      "params": [1.75, 0.75]
    },
    {
      "shader": "shaders/vhs_color_noise.frag",
      "samplers": ["yiq"],
      "output": "chrominance_noise",
      "params": [0.03125, 0.05, 50, 0.02]
    },
    {
      "shader": "shaders/fir_lowpass.frag",
      "samplers": ["chrominance_noise"],
      "output": "chrominance_lp",
      "params": [128, 0.1, 1.0]
    },
    {
      "shader": "shaders/blur_gaussian_13.frag",
      "samplers": ["chrominance_lp"],
      "output": "chrominance",
      "params": [0.0, 0.5]
    },
    {
      "shader": "shaders/vhs_swizzle_yiq.frag",
      "samplers": ["luminance", "chrominance"],
      "output": "yiq_swizzle",
      "params": []
    },
    {
      "shader": "shaders/vhs_dropout.frag",
      "samplers": ["yiq_swizzle"],
      "output": "dropout",
      "params": [0.9999999, 0.00001, 50, 32]
    },
    {
      "shader": "shaders/vhs_headswitch.frag",
      "samplers": ["dropout"],
      "output": "headswitch",
      "params": [1, 2, 0.05, 0.25]
    },
    {
      "shader": "shaders/vhs_tracking.frag",
      "samplers": ["headswitch"],
      "output": "tracking",
      "params": [70, 2.0, 4]
    },
    {
      "shader": "shaders/color_yiq_to_rgb.frag",
      "samplers": ["tracking"],
      "output": "result",
      "params": []
    }
  ]
}
