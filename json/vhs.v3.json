{
  "textures": {
    "image_sharpen":            { "width": 640, "height": 480, "filter": true },
    "image_gamma":              { "width": 640, "height": 480, "filter": true },
    "image_cutoff":             { "width": 640, "height": 480, "filter": true },
    "image_yiq":                { "width": 640, "height": 480, "filter": true },
    "luminance_blur":           { "width": 640, "height": 480, "filter": true },
    "luminance_blur_ds":        { "width": 320, "height": 480, "filter": true },
    "luminance_halo":           { "width": 640, "height": 480, "filter": true },
    "chrominance_noise":        { "width": 320, "height": 480, "filter": true },
    "chrominance_blur":         { "width": 640, "height": 480, "filter": true },
    "composite_yiq":            { "width": 640, "height": 480, "filter": true },
    "composite_yiq_dropout":    { "width": 320, "height": 240, "filter": true },
    "composite_yiq_switching":  { "width": 320, "height": 240, "filter": true },
    "composite_rgb":            { "width": 640, "height": 480, "filter": true }
  },
  "blit": "composite_rgb",
  "passes": [
    {
      "shader": "shaders/vid_sharpen.frag",
      "samplers": ["!image"],
      "output": "image_sharpen",
      "params": [0.5]
    },
    {
      "shader": "shaders/vid_gamma.frag",
      "samplers": ["image_sharpen"],
      "output": "image_gamma",
      "params": [0.5]
    },
    {
      "shader": "shaders/vhs_cutoff.frag",
      "samplers": ["image_gamma"],
      "output": "image_cutoff",
      "params": [0.01, 0.02]
    },
    {
      "shader": "shaders/convert_rgb_to_yiq.frag",
      "samplers": ["image_cutoff"],
      "output": "image_yiq",
      "params": []
    },
    {
      "shader": "shaders/gaussblur_fast5.frag",
      "samplers": ["image_yiq"],
      "output": "luminance_blur",
      "params": [1.0, 0.0]
    },
    {
      "shader": "shaders/gaussblur_fast5.frag",
      "samplers": ["image_yiq"],
      "output": "luminance_blur_ds",
      "params": [2.0, 0.0]
    },
    {
      "shader": "shaders/blend_subtract.frag",
      "samplers": ["luminance_blur", "luminance_blur_ds"],
      "output": "luminance_halo",
      "params": [2.0, 1.0]
    },
    {
      "shader": "shaders/ntsc_chroma_noise.frag",
      "samplers": ["image_yiq"],
      "output": "chrominance_noise",
      "params": [0.125, 0.05, 50, 0.02]
    },
    {
      "shader": "shaders/gaussblur_fast13.frag",
      "samplers": ["chrominance_noise"],
      "output": "chrominance_blur",
      "params": [1.5, 0.0]
    },
    {
      "shader": "shaders/ntsc_combine_yiq.frag",
      "samplers": ["luminance_halo", "chrominance_blur"],
      "output": "composite_yiq",
      "params": []
    },
    {
      "shader": "shaders/vhs_dropout.frag",
      "samplers": ["composite_yiq"],
      "output": "composite_yiq_dropout",
      "params": [0.9999995, 0.001, 200, 0.01]
    },
    {
      "shader": "shaders/vhs_head_switching.frag",
      "samplers": ["composite_yiq_dropout"],
      "output": "composite_yiq_switching",
      "params": [0.005, 0.5, 16]
    },
    {
      "shader": "shaders/convert_yiq_to_rgb.frag",
      "samplers": ["composite_yiq_switching"],
      "output": "composite_rgb",
      "params": []
    }
  ]
}
